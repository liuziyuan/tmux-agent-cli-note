{
  "name": "tmux-agent-cli-note",
  "version": "0.6.1",
  "description": "Vim-like brainstorm note tool for tmux, sends notes to AI CLI agents (Claude Code, OpenCode, Codex)",
  "main": "./dist/src/app.js",
  "bin": {
    "note": "./dist/bin/note.js"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "hooks/"
  ],
  "keywords": [
    "tmux",
    "note",
    "claude",
    "claude-code",
    "opencode",
    "codex",
    "vim",
    "brainstorm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/liuziyuan/tmux-agent-cli-note"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx bin/note.ts",
    "dev:args": "tsx bin/note.ts",
    "dev:build": "npm run build && node dist/bin/note.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
